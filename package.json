{
  "name": "saver-bot",
  "module": "index.ts",
  "type": "module",
  "private": true,
  "scripts": {
    "start": "bun run src/index.ts",
    "dev": "bun run --watch src/index.ts",
    "build": "bun build src/index.ts --outfile app --compile --minify --sourcemap --bytecode --external i18next-fs-backend",
    "lint": "eslint --fix --config eslint.config.mjs 'src/**/*.{js,ts}'",
    "format": "prettier --write .",
    "type-check": "tsc --noEmit",
    "lint-staged": "lint-staged"
  },
  "lint-staged": {
    "src/**/*.{ts,js}": "bun run lint",
    "src/**/*.{ts,js,json,md}": "bun run format"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "eslint": "^9.38.0",
    "eslint-config-next": "^15.5.6",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-jsdoc": "^61.1.4",
    "eslint-plugin-prettier": "^5.5.4",
    "eslint-plugin-simple-import-sort": "^12.1.1",
    "eslint-plugin-sort-keys-fix": "^1.1.2",
    "lint-staged": "^16.2.4",
    "prettier": "^3.6.2"
  },
  "peerDependencies": {
    "typescript": "^5.9.3"
  },
  "dependencies": {
    "@grammyjs/runner": "^2.0.3",
    "grammy": "^1.38.3",
    "i18next": "^25.6.0",
    "i18next-fs-backend": "^2.6.0"
  }
}
