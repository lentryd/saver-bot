# ================================================================================================
# КОНФИГУРАЦИОННЫЙ ФАЙЛ ПЕРЕМЕННЫХ ОКРУЖЕНИЯ
# ================================================================================================
# В этом файле хранятся названия переменных окружения, которые используются в проекте.
# Скопируйте этот файл в .env и заполните значения.
# 
# Файл .env НЕ должен попадать в git репозиторий!
# ================================================================================================

# ================================================================================================
# ОСНОВНЫЕ НАСТРОЙКИ БОТА
# ================================================================================================

# Токен Telegram бота (ОБЯЗАТЕЛЬНО)
# Получить у @BotFather в Telegram
# Пример: 1234567890:ABCdefGHIjklMNOpqrsTUVwxyz1234567890
BOT_TOKEN=

# Режим окружения
# Возможные значения: development, production
# В development режиме включается больше логирования и отладочной информации
NODE_ENV=development

# Уровень логирования
# Возможные значения: error, warn, info, debug
# debug - максимальный уровень логирования (только для разработки)
# info - стандартный уровень для продакшена
LOG_LEVEL=info

# ================================================================================================
# WEBHOOK И СЕРВЕР НАСТРОЙКИ
# ================================================================================================

# Использовать webhook вместо polling
# true - webhook режим (для продакшена)
# false - polling режим (для разработки)
USE_WEBHOOK=false

# URL webhook'а (ОБЯЗАТЕЛЬНО если USE_WEBHOOK=true)
# Полный URL включая https:// где Telegram будет отправлять обновления
# Пример: https://your-bot-domain.com
WEBHOOK_URL=

# Порт для HTTP сервера
# В webhook режиме - порт для получения обновлений от Telegram
# В polling режиме с API - порт для API эндпоинтов
PORT=3000

# ================================================================================================
# АДМИНИСТРАТОРЫ БОТА
# ================================================================================================

# Список Telegram ID администраторов бота (через запятую)
# Эти пользователи имеют доступ к команде /init и другим админским функциям
# Пример: 123456789,987654321,555666777
ADMINS=

# ================================================================================================
# ДОПОЛНИТЕЛЬНЫЕ НАСТРОЙКИ
# ================================================================================================

# Адрес YouTube сервиса
# По умолчанию: http://localhost:5001
# YOUTUBE_SERVICE_URL=http://localhost:5001

# Служебный чат/канал для заливки видео ради получения file_id.
# ОБЯЗАТЕЛЕН для отправки видео в inline-сообщения: Telegram не умеет
# скачивать прямые googlevideo/tiktok URL для inline-результатов.
# Создайте приватный канал, добавьте бота администратором и укажите его ID
# (например, -1001234567890).
STORAGE_CHAT_ID=5456060334

# Порт YouTube сервиса
# По умолчанию: 5001
# YOUTUBE_SERVICE_PORT=5001

# Адрес Redis сервиса
# По умолчанию: redis:6379
# REDIS_URL=localhost:6379

# Путь к базе данных SQLite для сессий
# По умолчанию: data/sessions.db
# DATABASE_PATH=data/sessions.db

# Таймаут для HTTP запросов в миллисекундах
# По умолчанию: 30000 (30 секунд)
# HTTP_TIMEOUT=30000

# Максимальное количество попыток повтора при ошибках
# По умолчанию: 3
# MAX_RETRY_ATTEMPTS=3